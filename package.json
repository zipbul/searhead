{
  "name": "knoldr",
  "version": "0.3.0",
  "private": true,
  "bin": {
    "knoldr": "src/cli/index.ts"
  },
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outfile=dist/knoldr.js --external @huggingface/transformers",
    "cycles": "bunx dpdm --no-warning --no-tree --exit-code circular:1 src",
    "db:generate": "bunx drizzle-kit generate --schema ./src/db/schema.ts --out ./drizzle --dialect postgresql",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "bunx drizzle-kit push --schema ./src/db/schema.ts --dialect postgresql --url $DATABASE_URL",
    "dev": "bun run src/index.ts",
    "docker:down": "docker compose down",
    "docker:test": "docker compose --profile test up -d --wait db-test",
    "docker:up": "docker compose up -d --wait db",
    "eval:golden": "bun run src/eval/cli.ts",
    "format": "bunx oxfmt . --check",
    "format:write": "bunx oxfmt .",
    "knip": "bunx knip",
    "lint": "bunx oxlint --type-aware",
    "setup": "docker compose up -d --wait db && bun run db:migrate",
    "start": "bun dist/knoldr.js",
    "test": "bun test",
    "test:db": "docker compose --profile test up -d --wait db-test && TEST_DATABASE_URL=postgres://knoldr:knoldr@localhost:5433/knoldr_test bun test tests/integration/ tests/e2e/",
    "test:e2e": "bun test tests/e2e/",
    "test:integration": "bun test tests/integration/",
    "test:unit": "bun test tests/unit/",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@huggingface/transformers": "^4.0.0",
    "@mozilla/readability": "^0.6.0",
    "drizzle-orm": "^0.45.2",
    "jsdom": "^29.0.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^28.0.1",
    "dpdm": "^4.2.0",
    "drizzle-kit": "^0.31.10",
    "knip": "^5.63.1",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "oxlint-tsgolint": "^0.11.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
